#: ../../source/settings.rst:96 e14808e21c5b4051bb1bc7ebd2e3f70d
msgid "``autoupdate_check_interval_hours``"
msgstr "``autoupdate_check_interval_hours``"

#: ../../source/settings.rst:97 5195c80256c14e778a3cf45f8dd0a4b4
