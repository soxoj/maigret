msgstr "``24``"

#: ../../source/settings.rst:98 5042d467e19542f18549b80dd7a8f855
msgid "How often to check for updates (in hours)"
msgstr "检查更新的间隔(单位:小时)"

#: ../../source/settings.rst:99 b52e153b8fa943c7bddfc730b2465564
msgid "``db_update_meta_url``"
